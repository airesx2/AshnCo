{
  "manifest_version": 3,
  "name": "AshnCo",
  "version": "1.0.0",
  "action": {},
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "src/content/main.js"
      ],
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "permissions": [
    "sidePanel",
    "tabs",
    "scripting",
    "storage",
    "identity",
    "tts"
  ],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https://cdn.jsdelivr.net"
  },
  "externally_connectable": {
    "matches": ["http://localhost/*"]
  },

  "web_accessible_resources": [
    {
      "resources": ["mediapipe/*"],
      "matches": ["https://twitter.com/*", "https://x.com/*"]
    }
  ]
  

}
