{
  "manifest_version": 3,
  "name": "AshnCo",
  "version": "1.0.0",
  "action": {},
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "src/content/mediapipe/hands.js",
        "src/content/mediapipe/camera_utils.js",
        "src/content/main.js"
      ],
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "permissions": [
    "sidePanel",
    "tabs",
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/content/mediapipe/*"],
      "matches": ["https://twitter.com/*", "https://x.com/*"]
    }
  ]

}
